{
  "entities": {
    "Lesson": {
      "title": "Lesson Record",
      "description": "A received piano or instrumental lesson recording logs and tips.",
      "type": "object",
      "properties": {
        "teacher": { "type": "string", "description": "The name of the instructor" },
        "topic": { "type": "string", "description": "The piece or topic studied" },
        "date": { "type": "string", "format": "date", "description": "Date of the lesson" },
        "feedback": { "type": "string", "description": "Librarian or teacher input" },
        "nextExercises": { "type": "string", "description": "Next steps/homework topics" },
        "userId": { "type": "string", "description": "The user owning this piece of data" },
        "createdAt": { "type": "object", "description": "Firebase server timestamp" }
      },
      "required": ["teacher", "topic", "date", "userId"]
    },
    "RepertoireItem": {
      "title": "Repertoire Item",
      "description": "A musical piece in the user's personal portfolio or list of sheet music.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the piece" },
        "composer": { "type": "string", "description": "The composer of the piece" },
        "notes": { "type": "string", "description": "Reminders, performance details, and score details" },
        "status": { "type": "string", "enum": ["Learning", "Polishing", "Completed"], "description": "Study status" },
        "sheetMusicUrl": { "type": "string", "description": "Simulated or actual sheet music storage URL" },
        "userId": { "type": "string", "description": "The user owning this piece" },
        "createdAt": { "type": "object", "description": "Firebase server timestamp" }
      },
      "required": ["title", "composer", "status", "userId"]
    },
    "Student": {
      "title": "Student",
      "description": "Information about a music student taught by the musician.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the student" },
        "level": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"], "description": "The student's playing level" },
        "currentPiece": { "type": "string", "description": "The current item the student is learning" },
        "userId": { "type": "string", "description": "The user owning this student" },
        "createdAt": { "type": "object", "description": "Firebase server timestamp" }
      },
      "required": ["name", "level", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}/received_lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Received lessons organized per user"
    },
    "/users/{userId}/repertoire/{repertoireId}": {
      "schema": "RepertoireItem",
      "description": "My notes and files on musical repertoire"
    },
    "/users/{userId}/students/{studentId}": {
      "schema": "Student",
      "description": "Studio students being instructed by this musician"
    }
  }
}
